# Development Environment - Copy this to .env.local
# Nest API (default port 3000). Frontend runs on 3001 — in dev the app proxies via /api-backend (see next.config.js).
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000
# Used by Next rewrites to forward /api-backend/* → Nest
BACKEND_URL=http://127.0.0.1:3000
# Set to "false" only if you want the browser to call NEXT_PUBLIC_API_URL directly (CORS must allow it).
# NEXT_PUBLIC_API_USE_PROXY=false
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_APP_NAME="Vendor Booking System (Dev)"
NEXT_PUBLIC_APP_VERSION="1.0.0-dev"
